<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- ── Metastore: MySQL backend ── -->
  <property>
    <name>javax.jdo.option.ConnectionURL</name>
    <value>jdbc:mysql://mysql:3306/hive_metastore?createDatabaseIfNotExist=true&amp;useSSL=false&amp;allowPublicKeyRetrieval=true</value>
  </property>
  <property>
    <name>javax.jdo.option.ConnectionDriverName</name>
    <value>com.mysql.cj.jdbc.Driver</value>
  </property>
  <property>
    <name>javax.jdo.option.ConnectionUserName</name>
    <value>hive</value>
  </property>
  <property>
    <name>javax.jdo.option.ConnectionPassword</name>
    <value>hivepass</value>
  </property>

  <!-- ── Warehouse location on HDFS ── -->
  <property>
    <name>hive.metastore.warehouse.dir</name>
    <value>hdfs://namenode:9000/user/hive/warehouse</value>
  </property>

  <!-- ── Metastore thrift URI (used by Spark and Beeline clients) ── -->
  <property>
    <name>hive.metastore.uris</name>
    <value>thrift://hive-metastore:9083</value>
  </property>

  <!-- ── HiveServer2 (Beeline endpoint) ── -->
  <property>
    <name>hive.server2.thrift.port</name>
    <value>10000</value>
  </property>
  <property>
    <name>hive.server2.enable.doAs</name>
    <value>false</value>
  </property>

  <!-- ── Use MapReduce as execution engine (Tez not installed) ── -->
  <property>
    <name>hive.execution.engine</name>
    <value>mr</value>
  </property>

  <!-- ── Disable notification event poll (Hive 4.x / MySQL fix) ── -->
  <!-- HiveServer2 fails on get_current_notificationEventId when NOTIFICATION_LOG -->
  <!-- table is not fully initialised. Disabling auth + poll avoids the crash.    -->
  <property>
    <name>hive.metastore.event.db.notification.api.auth</name>
    <value>false</value>
  </property>
  <property>
    <name>hive.notification.event.poll.interval</name>
    <value>-1</value>
  </property>

</configuration>